# Cloudflare Pages redirects
# Static prerendered files are served first; these only apply when no file matches

# Root redirect to default Arabic locale
/ /ar/ 302

# Legacy routes redirect to Arabic locale
/projects/* /ar/projects/:splat 302
/projects /ar/projects 302
/about /ar/about 302
/contact /ar/contact 302
/gallery /ar/gallery 302
/blog/* /ar/blog/:splat 302
/blog /ar/blog 302
/privacy /ar/privacy 302

# Admin SPA routes
/admin /admin/ 301
/admin/* /index.csr 200

# SPA fallback for all other client-rendered routes
/* /index.csr 200
