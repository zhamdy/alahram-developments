{
  "name": "alahram-developments",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:ssr": "node dist/alahram-developments/server/server.mjs",
    "prebuild": "node scripts/generate-sitemap.js",
    "build": "ng build",
    "build:staging": "ng build --configuration staging",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\"",
    "deploy": "npx wrangler pages deploy",
    "build:api": "tsc -p tsconfig.api.json",
    "start:api": "node dist-api/api-server.js",
    "db:seed": "npx tsx src/server/seed.ts",
    "docker:build": "docker build -t alahram-developments .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.1",
    "@jsverse/transloco": "^8.2.1",
    "@lucide/angular": "^1.7.0",
    "@ngrx/signals": "^21.0.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "gsap": "^3.14.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "swiper": "^12.1.3",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/schematics": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "wrangler": "^4.71.0"
  }
}
